      "source": [
        "## Look for Multicolinearity"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# to create a module function find VIF\n",
        "def find_multicollinear_features(df, threshold=0.8): # Changed default threshold to 5\n",
        "    \"\"\"\n",
        "    Returns features with high multicollinearity (VIF > threshold)\n",
        "    \"\"\"\n",
        "    from statsmodels.stats.outliers_influence import variance_inflation_factor\n",
        "    from statsmodels.tools.tools import add_constant\n",
        "    import pandas as pd\n",
        "\n",
        "    # Get the names of numeric columns, excluding 'Churn'\n",
        "    numeric_col_names = df.select_dtypes(include='number').columns.drop('Churn')\n",
        "\n",
        "    if numeric_col_names.empty:\n",
        "        print(\"No numeric features found to check for multicollinearity!\")\n",
        "        return pd.DataFrame() # Return empty DataFrame\n",
        "\n",
        "    # Select the actual numeric data from the DataFrame and drop rows with NaNs\n",
        "    # This X_data will be used for VIF calculation\n",
        "    X_data = df[numeric_col_names].dropna()\n",
        "\n",
        "    if X_data.empty:\n",
        "        print(\"No complete numeric observations after dropping NaNs for VIF calculation!\")\n",
        "        return pd.DataFrame() # Return empty DataFrame\n",
        "\n",
        "    # Add a constant to the DataFrame for VIF calculation\n",
        "    # statsmodels' VIF expects a constant term in the design matrix if you're modeling an intercept.\n",
        "    X_with_const = add_constant(X_data, prepend=False) # prepend=False to put const at the end\n",
        "\n",
        "    vif_data = pd.DataFrame()\n",
        "    vif_data[\"Feature\"] = X_with_const.columns\n",
        "    # Calculate VIF for each feature in X_with_const\n",
        "    vif_data[\"VIF\"] = [variance_inflation_factor(X_with_const.values, i)\n",
        "                       for i in range(X_with_const.shape[1])]\n",
        "\n",
        "    # Filter out the 'const' feature, as its VIF is usually not of interest for feature selection\n",
        "    vif_data = vif_data[vif_data['Feature'] != 'const']\n",
        "\n",
        "    # High VIF features filter karo\n",
        "    problematic = vif_data[vif_data[\"VIF\"] > threshold].sort_values(\"VIF\", ascending=False)\n",
        "\n",
        "    if not problematic.empty:\n",
        "        print(f\"🚨 Features with High Multicollinearity (VIF > {threshold}):\")\n",
        "        print(problematic.to_string(index=False))\n",
        "    else:\n",
        "        print(f\"✅ No significant multicollinearity found (all VIFs <= {threshold})!\")\n",
        "\n",
        "    return vif_data\n",
        "\n",
        "# Use karo:\n",
        "result = find_multicollinear_features(df)"
      ],
